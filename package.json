{
	"name": "biome-md",
	"description": "A simple CLI that format your code inside README files with Biome",
	"version": "0.0.1",
	"bin": {
		"biome-md": "./dist/cli.mjs"
	},
	"files": [
		"dist/cli.mjs"
	],
	"scripts": {
		"dev": "bun run ./src/cli.ts",
		"cli": "bun run ./dist/cli.mjs",
		"build": "tsdown",
		"type-check": "tsc --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@types/node": "20.17.24",
		"tsdown": "^0.15.10",
		"typescript": "5.6.3"
	},
	"peerDependencies": {
		"@biomejs/biome": ">=1.0.0"
	},
	"peerDependenciesMeta": {
		"@biomejs/biome": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=18"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rajatsandeepsen/biome-md.git"
	},
	"bugs": {
		"url": "https://github.com/rajatsandeepsen/biome-md/issues"
	},
	"keywords": [
		"biome",
		"markdown",
		"readme",
		"format",
		"cli"
	]
}
